# ── Supabase ─────────────────────────────────────────────────────────────────
# Get these from your Supabase project → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# ── Transactional email (SendGrid) ───────────────────────────────────────────
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM=hello@yourdomain.com

# ── Delivery partner ───────────────────────────────────────────────────────
DELIVERY_API_KEY=your-delivery-provider-key
DELIVERY_WEBHOOK_SECRET=your-delivery-webhook-secret

# If your webhooks provider supports signed payloads, set this secret for email webhooks
EMAIL_WEBHOOK_SECRET=your-email-webhook-secret

# ── Error monitoring (Sentry) ──────────────────────────────────────────────
SENTRY_DSN=your-sentry-dsn

# Optional: Supabase service role key for server-side operations (keep secret)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

